# AIX未来视野 - 环境配置
# 复制此文件为 .env 并根据需要修改

# 运行环境: development | uat | production
NODE_ENV=development

# 开发服务器配置 (cors-server.py)
STATIC_PORT=8000
API_PORT=8001
API_ORIGIN=https://aixfutureapi.vercel.app

# 三环境说明:
# development: 本地开发，前端 localhost:8000，API aixfutureapi.vercel.app
# uat: master 分支，前端 aixfuture.vercel.app，API aixfutureapi.vercel.app
# production: main 分支，前端 www.aixfuture.top，API www.aixfutrueapi.top

# 数据文件路径
DATA_FILE=data/models.json
MOCK_DATA_FILE=data/models.json.mock

# 爬虫配置
MAX_RETRIES=3
PAGE_LOAD_TIMEOUT=30000

# 数据源
SCRAPE_URL_GENERAL=https://www.superclueai.com/generalpage
SCRAPE_URL_REASONING=https://www.superclueai.com/reasoningpage
SCRAPE_URL_OPEN=https://www.superclueai.com/openpage
