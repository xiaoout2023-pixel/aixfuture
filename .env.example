# AIX未来视野 - 环境配置
# 复制此文件为 .env 并根据需要修改

# 运行环境: development | production
NODE_ENV=development

# 数据文件路径
# 开发环境使用 mock 数据，生产环境由爬虫生成
DATA_FILE=data/models.json
MOCK_DATA_FILE=data/models.json.mock

# 爬虫配置
MAX_RETRIES=3
PAGE_LOAD_TIMEOUT=30000

# 数据源
SCRAPE_URL_GENERAL=https://www.superclueai.com/generalpage
SCRAPE_URL_REASONING=https://www.superclueai.com/reasoningpage
SCRAPE_URL_OPEN=https://www.superclueai.com/openpage
